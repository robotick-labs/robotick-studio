{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "lib": ["DOM", "ES2022"],
    "strict": true,
    "noEmit": true, // Let Vite do the output
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "types": ["node"],
    "paths": {
      "@studio/*": ["src/renderer/*"],
      "@animation-plugin/*": ["../robotick-animation/studio/plugins/animation-editor/src/*"]
    }
  },
  "include": [
    "src/renderer/**/*",
    "src/electron/**/*",
    "../robotick-animation/studio/plugins/animation-editor/src/**/*"
  ]
}
