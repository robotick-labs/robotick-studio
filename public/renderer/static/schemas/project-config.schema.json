{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Robotick Project Config",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Project readable name"
    },
    "description": {
      "type": "string",
      "description": "Human-readable description"
    },
    "robotick_engine_root": {
      "type": "string",
      "description": "Relative path to the Robotick engine"
    },
    "local_workload_roots": {
      "type": "array",
      "description": "List of workload search paths",
      "items": { "type": "string" },
      "minItems": 1
    },
    "local_python_roots": {
      "type": "array",
      "description": "Python entry points (id/path/requirements) to hydrate via install-deps",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "path": { "type": "string" },
          "requirements": { "type": "string" }
        },
        "required": ["id", "path"]
      }
    }
  },
  "required": ["name", "robotick_engine_root", "local_workload_roots"],
  "additionalProperties": false
}
