{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "dist/electron",
    "rootDir": "src/electron",

    "module": "commonjs",
    "target": "ES2020",
    "moduleResolution": "node",

    "strict": true,
    "esModuleInterop": true,
    "sourceMap": true,
    "inlineSources": true
  },
  "include": ["src/electron/**/*"],
  "exclude": ["src/electron/__tests__"]
}
