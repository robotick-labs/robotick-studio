{
  "name": "robotick-studio",
  "version": "1.0.0",
  "description": "Robotick Studio Electron shell for the Robotick Hub web IDE",
  "main": "dist/electron/main/main.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test:cli": "npm --prefix tools/robotick-cli test",
    "test:hub": "PYTHONPATH=tools/robotick-hub/src pytest -q tools/robotick-hub/tests",
    "test": "npm run test:renderer && npm run test:electron",
    "typecheck": "tsc --noEmit",
    "test:launcher": "bash build-and-test-launcher.sh",
    "test:renderer": "vitest --run --project renderer",
    "pretest:renderer": "npm run test:launcher",
    "test:electron": "vitest --run --project electron",
    "pretest:electron": "npm run test:launcher",
    "build:electron": "tsc -p tsconfig.electron.json",
    "electron": "./run-studio-production.sh",
    "electron:direct": "npm run build:electron && electron .",
    "electron-dev": "./run-studio-dev.sh",
    "electron-dev:direct": "npm run build:electron && ELECTRON_DEV=1 ELECTRON_ENABLE_LOGGING=1 electron .",
    "dev:all": "concurrently -k -s command-electron -n vite,electron \"npm:dev\" \"npm:electron-dev:direct\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/robotick-labs/robotick-studio.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/robotick-labs/robotick-studio/issues"
  },
  "homepage": "https://github.com/robotick-labs/robotick-studio#readme",
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/jsdom": "^27.0.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@types/three": "^0.180.0",
    "@vitejs/plugin-react": "^5.2.0",
    "concurrently": "^9.2.1",
    "electron": "^39.2.6",
    "jsdom": "^27.2.0",
    "typescript": "^5.9.3",
    "vite": "^7.1.10",
    "vite-plugin-cesium": "^1.2.23",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "ansi_up": "^6.0.6",
    "cesium": "^1.134.1",
    "elkjs": "^0.10.2",
    "fast-png": "^8.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.9.6",
    "three": "^0.180.0",
    "three-stdlib": "^2.36.0"
  }
}
