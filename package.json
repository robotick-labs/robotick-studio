{
  "name": "robotick-studio",
  "version": "1.0.0",
  "description": "Robotick Studio Electron shell for the Robotick Hub web IDE",
  "main": "dist/electron/main/main.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "npm run test:renderer && npm run test:electron",
    "test:renderer": "vitest --run --project renderer",
    "test:electron": "vitest --run --project electron",
    "build:electron": "tsc -p tsconfig.electron.json",
    "electron": "npm run build:electron && electron .",
    "electron-dev": "npm run build:electron && ELECTRON_DEV=1 ELECTRON_ENABLE_LOGGING=1 electron . --remote-debugging-port=9222",
    "dev:all": "concurrently \"npm:dev\" \"npm:electron-dev\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/robotick-labs/robotick-studio.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/robotick-labs/robotick-studio/issues"
  },
  "homepage": "https://github.com/robotick-labs/robotick-studio#readme",
  "devDependencies": {
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@types/three": "^0.180.0",
    "concurrently": "^9.2.1",
    "electron": "^28.3.3",
    "jsdom": "^27.2.0",
    "typescript": "^5.9.3",
    "vite": "^7.1.10",
    "vite-plugin-cesium": "^1.2.23",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "ansi_up": "^6.0.6",
    "cesium": "^1.134.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.9.6",
    "three": "^0.180.0",
    "three-stdlib": "^2.36.0"
  }
}
